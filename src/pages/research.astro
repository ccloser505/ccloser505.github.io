---
import SidebarLayout from '../layouts/SidebarLayout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { publicationsByType } from '../data/publications';
---
<SidebarLayout title="Research">
  <header class="mb-12">
    <h1 class="font-display font-extrabold text-3xl mb-3 tracking-tight">Research</h1>
    <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed">
      My work asks how partnership, reproduction, and marriage are being
      decoupled in late-low-fertility Korea — and what this transition means
      for gender, intimacy, and the structure of intergenerational ties.
    </p>
  </header>

  <section class="mb-14">
    <p class="section-label mb-2">Peer-Reviewed</p>
    <div>
      {publicationsByType['peer-reviewed'].map((pub) => (
        <PublicationCard publication={pub} />
      ))}
    </div>
  </section>

  <section class="mb-14">
    <p class="section-label mb-2">Research Reports</p>
    <div>
      {publicationsByType['report'].map((pub) => (
        <PublicationCard publication={pub} />
      ))}
    </div>
  </section>

  <section>
    <p class="section-label mb-2">Works in Progress</p>
    <div>
      {publicationsByType['work-in-progress'].map((pub) => (
        <PublicationCard publication={pub} />
      ))}
    </div>
  </section>
</SidebarLayout>
