---
import { profile } from '../data/profile';

const baseUrl = import.meta.env.BASE_URL;
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-bg)]/90 backdrop-blur-sm border-b border-[var(--color-border)]">
  <div class="px-6 lg:px-10 h-14 flex items-center justify-between">
    <a
      href={baseUrl}
      class="font-display text-base tracking-tight hover:opacity-60 transition-opacity"
      aria-label="Home"
    >
      {profile.name.en}
    </a>

    <button
      type="button"
      data-menu-open
      class="font-display text-base tracking-tight hover:opacity-60 transition-opacity cursor-pointer"
      aria-label="Open menu"
      aria-haspopup="dialog"
    >
      Menu
    </button>
  </div>
</nav>
