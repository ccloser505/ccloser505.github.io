---
import { navigation } from '../data/navigation';
import { profile } from '../data/profile';

const baseUrl = import.meta.env.BASE_URL;

function resolve(href: string) {
  if (href.startsWith('#')) return href;
  if (href === '/') return baseUrl;
  return `${baseUrl.replace(/\/$/, '')}${href}`;
}
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-bg)]/90 backdrop-blur-sm border-b border-[var(--color-border)]">
  <div class="px-6 lg:px-10 h-14 flex items-center gap-5 lg:gap-8 overflow-x-auto">
    <a
      href={baseUrl}
      class="font-display font-extrabold text-base tracking-tight hover:text-[var(--color-accent)] transition-colors duration-200 whitespace-nowrap shrink-0"
      aria-label="Home"
    >
      {profile.name.en}
    </a>
    <ul class="flex items-center gap-4 lg:gap-6 text-sm tracking-wide">
      {navigation.map((item) => (
        <li class="shrink-0">
          <a
            href={resolve(item.href)}
            data-nav-anchor={item.href}
            class="nav-link font-display font-extrabold text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors duration-200 whitespace-nowrap"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .nav-link.is-active {
    color: var(--color-accent);
  }
</style>

<script>
  // Highlight the nav link whose section is currently in view.
  // The rootMargin defines a narrow band (top 30% to bottom 40% of viewport)
  // — a section becomes "active" only while inside that band, so only one
  // link is highlighted at a time.
  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-nav-anchor]');

  if (sections.length > 0 && links.length > 0 && 'IntersectionObserver' in window) {
    const setActive = (id: string | null) => {
      links.forEach((link) => {
        const anchor = link.dataset.navAnchor;
        link.classList.toggle('is-active', anchor === `#${id}`);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
          }
        });
      },
      {
        rootMargin: '-30% 0px -60% 0px',
        threshold: 0,
      }
    );

    sections.forEach((s) => observer.observe(s));
  }
</script>
