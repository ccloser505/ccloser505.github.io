---
import { navigation } from '../data/navigation';
import { profile } from '../data/profile';

const baseUrl = import.meta.env.BASE_URL;

function resolve(href: string) {
  if (href.startsWith('#')) return href;
  if (href === '/') return baseUrl;
  return `${baseUrl.replace(/\/$/, '')}${href}`;
}
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-bg)]/90 backdrop-blur-sm border-b border-[var(--color-border)]">
  <div class="px-6 lg:px-10 h-14 flex items-center gap-8 lg:gap-14 overflow-x-auto">
    <a
      href={baseUrl}
      class="font-display font-extrabold text-base tracking-tight hover:text-[var(--color-accent)] transition-colors duration-200 whitespace-nowrap shrink-0"
      aria-label="Home"
    >
      {profile.name.en}
    </a>
    <ul class="flex items-center gap-4 lg:gap-6 text-sm tracking-wide">
      {navigation.map((item) => (
        <li class="shrink-0">
          <a
            href={resolve(item.href)}
            data-nav-anchor={item.href}
            class="nav-link font-display font-extrabold text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors duration-200 whitespace-nowrap"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .nav-link.is-active {
    color: var(--color-accent);
  }
</style>

<script>
  // Scroll-spy: highlight the nav link of the section the reader is on.
  // Uses scroll position rather than IntersectionObserver so the bottom
  // edge case (last section too short to enter the observer band) works:
  // if we're scrolled to the bottom of the page, force the last section
  // active regardless of its height.
  const sections = Array.from(
    document.querySelectorAll<HTMLElement>('section[id]')
  );
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-nav-anchor]');

  if (sections.length > 0 && links.length > 0) {
    const setActive = (id: string) => {
      links.forEach((link) => {
        link.classList.toggle('is-active', link.dataset.navAnchor === `#${id}`);
      });
    };

    let ticking = false;
    const updateActive = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const scrolledToBottom =
          window.innerHeight + window.scrollY >=
          document.documentElement.scrollHeight - 4;

        if (scrolledToBottom) {
          setActive(sections[sections.length - 1].id);
        } else {
          // Trigger line at 35% from the top of the viewport. Last section
          // whose top has crossed this line wins.
          const triggerY = window.scrollY + window.innerHeight * 0.35;
          let activeId = sections[0].id;
          for (const section of sections) {
            if (section.offsetTop <= triggerY) {
              activeId = section.id;
            }
          }
          setActive(activeId);
        }
        ticking = false;
      });
    };

    window.addEventListener('scroll', updateActive, { passive: true });
    window.addEventListener('resize', updateActive, { passive: true });
    updateActive();
  }
</script>
