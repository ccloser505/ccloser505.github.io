---
import type { Presentation } from '../data/presentations';

interface Props {
  presentation: Presentation;
}

const { presentation } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const detailUrl = `${baseUrl.replace(/\/$/, '')}/presentations/${presentation.slug}/`;
const pdfUrl = presentation.pdf ? `${baseUrl}${presentation.pdf}` : null;
---
<article
  class="group relative py-5 px-4 -mx-4 lg:px-6 lg:-mx-6 rounded-sm
         border-b border-[var(--color-border)] last:border-b-0
         hover:bg-[var(--color-bg-sidebar)] transition-colors duration-150"
>
  <p class="text-xs text-[var(--color-text-muted)] mb-2 tracking-wide">
    {presentation.date}
    {presentation.note && (
      <span> · {presentation.note}</span>
    )}
  </p>
  <h3 class="font-display text-lg font-extrabold leading-snug mb-2">
    <a
      href={detailUrl}
      class="hover:text-[var(--color-accent)] transition-colors
             before:absolute before:inset-0 before:content-['']"
      aria-label={`Read more: ${presentation.title}`}
    >
      {presentation.title}
    </a>
  </h3>
  <p class="text-sm text-[var(--color-text-secondary)]">
    <span class="italic">{presentation.event}</span>
    <span class="text-[var(--color-text-muted)]"> · {presentation.location}</span>
  </p>
  {pdfUrl && (
    <a
      href={pdfUrl}
      class="relative inline-flex items-center gap-1.5 mt-3 text-xs font-display font-extrabold tracking-wide
             text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors"
      target="_blank"
      rel="noopener noreferrer"
      download
      aria-label={`Download slides: ${presentation.title}`}
    >
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3" />
      </svg>
      Slides
    </a>
  )}
</article>
