---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import MenuOverlay from '../components/MenuOverlay.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, tags = [] } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const baseUrl = import.meta.env.BASE_URL;
const blogIndexUrl = `${baseUrl.replace(/\/$/, '')}/blog/`;
---
<BaseLayout title={title} description={description}>
  <Nav />
  <article class="pt-14 max-w-2xl mx-auto px-6 lg:px-8 py-16 lg:py-20">
    <a
      href={blogIndexUrl}
      class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text)] inline-block mb-8 tracking-wide"
    >
      ← Back to Blog
    </a>

    <header class="mb-12 pb-8 border-b border-[var(--color-border)]">
      <h1 class="font-display font-bold text-3xl lg:text-4xl leading-tight mb-5">{title}</h1>
      <div class="flex flex-wrap items-center gap-x-3 text-xs text-[var(--color-text-muted)]">
        <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
        {updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>Updated {fmt(updatedDate)}</span>
          </>
        )}
        {tags.length > 0 && (
          <>
            <span aria-hidden="true">·</span>
            <span>{tags.join(', ')}</span>
          </>
        )}
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
  <MenuOverlay />
</BaseLayout>
