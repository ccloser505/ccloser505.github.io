---
import '../styles/global.css';
import { profile } from '../data/profile';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'profile';
  publishDate?: Date;
}

const {
  title,
  description = `${profile.name.en} — ${profile.tagline}`,
  ogImage,
  ogType = 'website',
  publishDate,
} = Astro.props;

const siteName = profile.name.en;
const fullTitle = title ? `${title} · ${siteName}` : `${siteName} | ${profile.name.ko}`;
const baseUrl = import.meta.env.BASE_URL;
const siteOrigin = (Astro.site ?? new URL('https://ccloser505.github.io')).origin;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? siteOrigin).href;
const ogImageUrl = new URL(ogImage ?? `${baseUrl}${profile.profileImage}`, siteOrigin).href;

// JSON-LD Person schema (sitewide identity for the site owner)
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name.en,
  alternateName: profile.name.ko,
  jobTitle: profile.title,
  affiliation: {
    '@type': 'EducationalOrganization',
    name: profile.affiliation,
  },
  url: siteOrigin,
  image: new URL(`${baseUrl}${profile.profileImage}`, siteOrigin).href,
  email: `mailto:${profile.email}`,
  knowsAbout: profile.researchInterests,
  alumniOf: profile.education.map((edu) => ({
    '@type': 'EducationalOrganization',
    name: edu.institution,
  })),
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={profile.name.en} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link rel="icon" href={`${baseUrl}favicon.ico`} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:locale:alternate" content="ko_KR" />
    {publishDate && (
      <meta property="article:published_time" content={publishDate.toISOString()} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Sitemap -->
    <link rel="sitemap" type="application/xml" href={`${baseUrl}sitemap-index.xml`} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body class="bg-[var(--color-bg)] text-[var(--color-text)] min-h-screen">
    <slot />
  </body>
</html>
